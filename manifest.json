{
  "manifest_version": 3,
  "name": "Permafeed",
  "version": "0.0.1",
  "description": "Freeze your YouTube home feed so it stops regenerating on navigation, plus a searchable log of videos you've seen on Home.",
  "permissions": ["storage"],
  "host_permissions": ["https://www.youtube.com/*"],
  "action": {
    "default_title": "Permafeed",
    "default_popup": "src/popup/popup.html"
  },
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["src/content/selectors.js", "src/content/content.js"],
      "run_at": "document_start"
    }
  ]
}
